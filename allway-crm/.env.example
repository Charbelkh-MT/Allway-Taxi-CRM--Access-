# --- Server-side only (Vercel env vars, never expose to client) ---

# Supabase service role key (bypasses RLS — server use only)
SUPABASE_URL=https://xwhvlyqirzknuxlcqsqq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Daily WhatsApp report (CallMeBot — free personal WhatsApp API)
# How to get your API key: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1. Add +34 644 60 77 99 to your WhatsApp contacts as "CallMeBot"
# 2. Send "I allow callmebot to send me messages" to that number
# 3. You'll receive your API key by WhatsApp
# Phone format: country code + number, no + or spaces (e.g. 96170000000)
# For multiple recipients, separate with commas: 96170000000,96171111111
WHATSAPP_PHONES=96170000000
CALLMEBOT_APIKEY=your_callmebot_apikey_here

# Cron security secret — set the same value in Vercel project settings
CRON_SECRET=your_random_secret_here
